    {
      "id": 1,
      "title": "Спагетти Карбонара",
      "ingredients": "[{\"name\":\"Спагетти - 400г, Бекон - 200г, Яйца - 3 шт, Пармезан - 100г, Чеснок - 2 зубчика, Сливки - 100мл, Соль, Перец\",\"amount\":\"1\",\"unit\":\"г\"}]",
      "instructions": "[{\"description\":\"1. Отварите спагетти согласно инструкции на упаковке.\",\"hasImage\":false},{\"description\":\"2. Обжарьте бекон до хрустящей корочки.\",\"hasImage\":false},{\"description\":\"3. Взбейте яйца со сливками и тертым пармезаном.\",\"hasImage\":false},{\"description\":\"4. Смешайте горячие спагетти с беконом, затем добавьте яичную смесь.\",\"hasImage\":false},{\"description\":\"5. Быстро перемешайте до образования кремовой текстуры.\",\"hasImage\":false}]",
      "cooking_time": 25,
      "category": "Паста",
      "difficulty": "Средний",
      "image_url": "/uploads/recipes/20251223_114445_b18c1fd6.jpg",
