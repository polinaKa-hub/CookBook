    {
      "id": 4,
      "title": "Тирамису",
      "ingredients": "[{\"name\":\"Маскарпоне - 500г, Яйца - 4 шт, Сахар - 100г, Печенье Савоярди - 200г, Кофе эспрессо - 300мл, Какао-порошок - 2 ст.л., Ликер Амаретто - 50мл\",\"amount\":\"0.9\",\"unit\":\"г\"}]",
      "instructions": "[{\"description\":\"1. Приготовьте кофе и остудите.\",\"hasImage\":false},{\"description\":\"2. Взбейте желтки с сахаром, добавьте маскарпоне.\",\"hasImage\":false},{\"description\":\"3. Взбейте белки и аккуратно вмешайте в крем.\",\"hasImage\":false},{\"description\":\"4. Быстро обмакните печенье в кофе с ликером.\",\"hasImage\":false},{\"description\":\"5. Выложите слоями: печенье, крем, печенье, крем.\",\"hasImage\":false},{\"description\":\"6. Посыпьте какао и охлаждайте 6 часов.\",\"hasImage\":false}]",
