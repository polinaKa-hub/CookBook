      "ingredients": "[{\"name\":\"Мука - 200г, Какао - 50г, Сахар - 250г, Яйца - 4 шт, Сливочное масло - 200г, Разрыхлитель - 2 ч.л., Сметана - 200г, Шоколад - 100г\",\"amount\":\"1\",\"unit\":\"г\"}]",
