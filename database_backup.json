    {
      "id": 5,
      "title": "Курица терияки",
      "ingredients": "[{\"name\":\"Куриное филе - 500г, Соус терияки - 100мл, Мед - 2 ст.л., Чеснок - 3 зубчика, Имбирь - 1 см, Кунжут, Растительное масло\",\"amount\":\"1\",\"unit\":\"г\"}]",
      "instructions": "[{\"description\":\"1. Нарежьте курицу кубиками.\",\"hasImage\":false},{\"description\":\"2. Приготовьте маринад: соус терияки, мед, чеснок, имбирь.\",\"hasImage\":false},{\"description\":\"3. Замаринуйте курицу на 30 минут.\",\"hasImage\":false},{\"description\":\"4. Обжарьте на сильном огне до золотистой корочки.\",\"hasImage\":false},{\"description\":\"5. Подавайте с рисом, посыпав кунжутом.\",\"hasImage\":false}]",
