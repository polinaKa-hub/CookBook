    {
      "id": 3,
      "title": "Борщ украинский",
      "ingredients": "[{\"name\":\"Говядина \",\"amount\":\"500\",\"unit\":\"г\"},{\"name\":\"Свекла\",\"amount\":\"2\",\"unit\":\"шт\"},{\"name\":\"Капуста \",\"amount\":\"299.9\",\"unit\":\"г\"},{\"name\":\"Картофель\",\"amount\":\"3\",\"unit\":\"шт\"},{\"name\":\"Морковь\",\"amount\":\"1\",\"unit\":\"шт\"},{\"name\":\" Лук \",\"amount\":\"1\",\"unit\":\"шт\"},{\"name\":\"Томатная паста \",\"amount\":\"2\",\"unit\":\"ст.л.\"},{\"name\":\"Сметана для подачи\",\"amount\":\"1\",\"unit\":\"ст.л.\"}]",
      "instructions": "[{\"description\":\"1. Сварите бульон из говядины.\",\"hasImage\":true},{\"description\":\"2. Нарежьте овощи: свеклу соломкой, капусту, картофель кубиками.\",\"hasImage\":true},{\"description\":\"3. Обжарьте лук, морковь и свеклу с томатной пастой.\",\"hasImage\":true},{\"description\":\"4. Добавьте овощи в бульон и варите до готовности.\",\"hasImage\":true},{\"description\":\"5. Подавайте со сметаной.\",\"hasImage\":true}]",
      "cooking_time": 90,
      "category": "Супы",
