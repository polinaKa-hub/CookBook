    {
      "id": 2,
      "title": "Салат Цезарь",
      "ingredients": "[{\"name\":\"Листья салата Романо\",\"amount\":\"1\",\"unit\":\"шт\"},{\"name\":\"Куриное филе \",\"amount\":\"300\",\"unit\":\"г\"},{\"name\":\"Сухарики \",\"amount\":\"100\",\"unit\":\"г\"},{\"name\":\"Пармезан\",\"amount\":\"50\",\"unit\":\"г\"},{\"name\":\"Яйца\",\"amount\":\"2\",\"unit\":\"шт\"},{\"name\":\"Чеснок\",\"amount\":\"2\",\"unit\":\"шт\"},{\"name\":\"Оливковое масло, Лимонный сок\",\"amount\":\"1\",\"unit\":\"шт\"}]",
      "instructions": "[{\"description\":\"1. Обжарьте куриное филе до готовности и нарежьте кубиками.\",\"hasImage\":true},{\"description\":\"2. Приготовьте соус: смешайте желтки, чеснок, лимонный сок и оливковое масло.\",\"hasImage\":true},{\"description\":\"3. Крупно нарвите листья салата.\",\"hasImage\":true},{\"description\":\"4. Соберите салат: салат, курица, сухарики, заправка.\",\"hasImage\":true},{\"description\":\"5. Посыпьте тертым пармезаном.\",\"hasImage\":true}]",
